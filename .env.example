# Copy this file to `.dev.vars` (gitignored) and fill in real values for local dev.
# In production these live in the Cloudflare Pages dashboard as encrypted env vars.

# Asana developer console -> your OAuth app
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=

# Must exactly match the redirect URI configured on the Asana OAuth app (trailing slash included/excluded consistently)
ASANA_REDIRECT_URI=http://localhost:8788/auth/callback

# GID of the Inner Excellence workspace - GET /workspaces in the Asana API explorer, or the workspace URL
ASANA_ALLOWED_WORKSPACE_GID=

# Optional. Defaults to "default" (requires "Full permissions" on the app).
# Set space-delimited granular scopes instead if the app is registered with them, e.g.:
# ASANA_OAUTH_SCOPE=users:read workspaces:read tasks:read tasks:write projects:read
ASANA_OAUTH_SCOPE=
