{
  "name": "simple-asana-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Asana dashboard on Cloudflare Pages with OAuth (see BUILD_SPEC.md)",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev -- vite --port 5173",
    "build": "vite build && wrangler pages functions build --outdir=dist",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
